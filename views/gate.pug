doctype html
html(lang="zh-TW")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title #{title}
    script(src="https://cdn.tailwindcss.com")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
    link(href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;700;900&family=Share+Tech+Mono&display=swap", rel="stylesheet")
    link(rel="stylesheet", href="/stylesheets/gate.css")
  
  body(class="flex flex-col h-screen w-screen text-slate-200")
    // 頂部導航
    header(class="bg-slate-800 border-b border-slate-700 p-3 flex justify-between items-center z-20 shadow-md")
      div(class="flex items-center gap-3")
        i(class="fa-solid fa-microchip text-blue-400 text-2xl")
        h1(class="text-xl font-bold tracking-wider") 數位邏輯模擬器 
          span(class="text-xs text-slate-400 font-normal") Quartus Web Edition
      div(class="flex items-center gap-3 text-sm")
        button(onclick="clearWorkspace()", class="bg-slate-700 hover:bg-slate-600 text-slate-300 px-3 py-1.5 rounded border border-slate-600 transition")
          i(class="fa-solid fa-trash mr-1 text-red-400")
          | 清空
        button#btn-wave(onclick="toggleWaveform()", class="bg-blue-600 hover:bg-blue-500 text-white px-3 py-1.5 rounded border border-blue-500 transition shadow")
          i(class="fa-solid fa-pause mr-1")
          | 暫停波形
        button#btn-autoscan(onclick="toggleAutoScan()", class="bg-green-600 hover:bg-green-500 text-white px-3 py-1.5 rounded border border-green-500 transition shadow font-bold")
          i(class="fa-solid fa-forward-step mr-1")
          | 自動波形掃描
        button(onclick="generateTruthTable()", class="bg-purple-600 hover:bg-purple-500 text-white px-4 py-1.5 rounded border border-purple-500 transition shadow font-bold")
          i(class="fa-solid fa-table-list mr-1")
          | 真值表

    // 中間工作區
    div(class="flex flex-1 overflow-hidden relative")
      // 左側工具欄
      aside(class="w-[280px] bg-slate-800 border-r border-slate-700 p-4 flex flex-col gap-3 z-20 shadow-xl overflow-y-auto")
        h2(class="text-slate-400 font-bold text-xs uppercase tracking-wider border-b border-slate-600 pb-1") I/O 節點 (Inputs / Outputs)
        div(class="grid grid-cols-2 gap-2")
          div(class="palette-item bg-slate-700 border border-slate-500 rounded p-2 flex flex-col items-center justify-center text-slate-300", onmousedown="startDragNewNode(event, 'SWITCH')")
            i(class="fa-solid fa-toggle-on text-2xl text-blue-400 mb-1")
            span(class="text-[10px] font-bold") Switch (開關)
          div(class="palette-item bg-slate-700 border border-slate-500 rounded p-2 flex flex-col items-center justify-center text-slate-300", onmousedown="startDragNewNode(event, 'CLOCK')")
            i(class="fa-solid fa-stopwatch text-2xl text-purple-400 mb-1")
            span(class="text-[10px] font-bold") Clock (時脈)
          div(class="palette-item bg-slate-700 border border-slate-500 rounded p-2 flex flex-col items-center justify-center text-slate-300 col-span-2", onmousedown="startDragNewNode(event, 'LED')")
            i(class="fa-regular fa-lightbulb text-2xl text-yellow-400 mb-1")
            span(class="text-[10px] font-bold") LED (輸出燈泡)

        h2(class="text-slate-400 font-bold mt-2 text-xs uppercase tracking-wider border-b border-slate-600 pb-1") 標準邏輯閘 (Logic Gates)
        div(class="grid grid-cols-2 gap-2")
          div(class="palette-item bg-slate-700 border rounded p-2 flex flex-col items-center text-blue-300 border-blue-500/50", onmousedown="startDragNewNode(event, 'AND')")
            svg(width="40", height="25", viewBox="0 0 60 40", fill="none", stroke="currentColor", stroke-width="4")
              path(d="M 15 5 V 35 H 30 A 15 15 0 0 0 30 5 H 15 Z")
            span(class="text-[10px] font-bold mt-1") AND
          div(class="palette-item bg-slate-700 border rounded p-2 flex flex-col items-center text-blue-300 border-blue-500/50", onmousedown="startDragNewNode(event, 'NAND')")
            svg(width="40", height="25", viewBox="0 0 60 40", fill="none", stroke="currentColor", stroke-width="4")
              path(d="M 10 5 V 35 H 25 A 15 15 0 0 0 25 5 H 10 Z")
              circle(cx="45", cy="20", r="4")
            span(class="text-[10px] font-bold mt-1") NAND
          div(class="palette-item bg-slate-700 border rounded p-2 flex flex-col items-center text-purple-300 border-purple-500/50", onmousedown="startDragNewNode(event, 'OR')")
            svg(width="40", height="25", viewBox="0 0 60 40", fill="none", stroke="currentColor", stroke-width="4")
              path(d="M 10 5 C 25 5 40 10 50 20 C 40 30 25 35 10 35 C 20 25 20 15 10 5 Z")
            span(class="text-[10px] font-bold mt-1") OR
          div(class="palette-item bg-slate-700 border rounded p-2 flex flex-col items-center text-purple-300 border-purple-500/50", onmousedown="startDragNewNode(event, 'NOR')")
            svg(width="40", height="25", viewBox="0 0 60 40", fill="none", stroke="currentColor", stroke-width="4")
              path(d="M 5 5 C 20 5 35 10 45 20 C 35 30 20 35 5 35 C 15 25 15 15 5 5 Z")
              circle(cx="50", cy="20", r="4")
            span(class="text-[10px] font-bold mt-1") NOR
          div(class="palette-item bg-slate-700 border rounded p-2 flex flex-col items-center text-green-300 border-green-500/50", onmousedown="startDragNewNode(event, 'XOR')")
            svg(width="40", height="25", viewBox="0 0 60 40", fill="none", stroke="currentColor", stroke-width="4")
              path(d="M 16 5 C 31 5 46 10 54 20 C 46 30 31 35 16 35 C 26 25 26 15 16 5 Z")
              path(d="M 8 5 C 18 15 18 25 8 35")
            span(class="text-[10px] font-bold mt-1") XOR
          div(class="palette-item bg-slate-700 border rounded p-2 flex flex-col items-center text-green-300 border-green-500/50", onmousedown="startDragNewNode(event, 'XNOR')")
            svg(width="40", height="25", viewBox="0 0 60 40", fill="none", stroke="currentColor", stroke-width="4")
              path(d="M 11 5 C 26 5 41 10 49 20 C 41 30 26 35 11 35 C 21 25 21 15 11 5 Z")
              path(d="M 3 5 C 13 15 13 25 3 35")
              circle(cx="54", cy="20", r="4")
            span(class="text-[10px] font-bold mt-1") XNOR
          div(class="palette-item bg-slate-700 border rounded p-2 flex flex-col items-center text-red-300 col-span-2 border-red-500/50", onmousedown="startDragNewNode(event, 'NOT')")
            svg(width="40", height="25", viewBox="0 0 60 40", fill="none", stroke="currentColor", stroke-width="4")
              polygon(points="15,5 15,35 40,20")
              circle(cx="45", cy="20", r="4")
            span(class="text-[10px] font-bold mt-1") NOT Gate

        h2(class="text-slate-400 font-bold mt-2 text-xs uppercase tracking-wider border-b border-slate-600 pb-1") 進階邏輯 (Advanced)
        div(class="grid grid-cols-2 gap-2")
          div(class="palette-item bg-slate-700 border rounded p-2 flex flex-col items-center text-teal-300 border-teal-500/50", onmousedown="startDragNewNode(event, 'MUX')")
            svg(width="40", height="25", viewBox="0 0 40 60", fill="none", stroke="currentColor", stroke-width="3", stroke-linejoin="round")
              polygon(points="5,5 35,15 35,45 5,55")
              text(x="20", y="34", fill="currentColor", stroke="none", font-size="12", font-family="sans-serif", text-anchor="middle", font-weight="bold") MUX
            span(class="text-[10px] font-bold mt-1") 2:1 MUX
          div(class="palette-item bg-slate-700 border rounded p-2 flex flex-col items-center text-orange-300 border-orange-500/50", onmousedown="startDragNewNode(event, 'DFF')")
            svg(width="40", height="25", viewBox="0 0 50 60", fill="none", stroke="currentColor", stroke-width="3", stroke-linejoin="round")
              rect(x="5", y="5", width="40", height="50")
              polyline(points="5,40 15,45 5,50")
              text(x="25", y="36", fill="currentColor", stroke="none", font-size="14", font-weight="bold", font-family="sans-serif", text-anchor="middle") D
            span(class="text-[10px] font-bold mt-1") D Flip-Flop
        
        div(class="mt-auto pt-2 text-xs text-slate-500 border-t border-slate-700 leading-relaxed")
          i(class="fa-solid fa-circle-info mr-1")
          | 點擊上方 
          span(class="text-green-400 font-bold") 自動波形掃描
          | ，系統將代為切換所有開關，產生時序波形！

      // 主畫布區
      main#workspace(class="flex-1 h-full relative", onmousemove="handleMouseMove(event)", onmouseup="handleMouseUp(event)")
        svg#wire-layer
          path#temp-wire(class="wire-path hidden", stroke="#94a3b8")
        div#nodes-container

    // 底部：波形檢視器
    div#waveform-container(class="h-64 flex flex-col shrink-0")
      div(class="bg-slate-800 px-4 py-1 flex justify-between items-center border-b border-slate-700 text-xs text-slate-300 font-bold tracking-wider")
        span
          i(class="fa-solid fa-chart-line text-blue-400 mr-2")
          | 即時波形分析儀 (Simulation Waveforms)
        span#sim-time(class="text-slate-500 font-mono") Time: 0 ns
      div#canvas-wrapper(class="flex-1 relative overflow-hidden")
        canvas#waveformCanvas(class="absolute top-0 left-0 w-full h-full")

    // Testbench 真值表 Modal 彈窗
    div#tt-modal(class="fixed inset-0 bg-black/80 flex justify-center items-center z-50 hidden opacity-0 transition-opacity duration-300")
      div#tt-modal-content(class="bg-slate-800 border border-slate-600 rounded-xl p-6 shadow-2xl min-w-[400px] max-w-[80vw] max-h-[80vh] flex flex-col transform scale-95 transition-transform duration-300")
        div(class="flex justify-between items-center mb-4 border-b border-slate-600 pb-3")
          h2(class="text-2xl font-bold text-purple-400")
            i(class="fa-solid fa-table-list mr-2")
            | 自動真值表驗證 (Truth Table)
          button(onclick="closeTTModal()", class="text-slate-400 hover:text-white text-2xl transition")
            i(class="fa-solid fa-xmark")
        
        p(class="text-sm text-slate-400 mb-4") 系統已掃描所有 Switch 作為輸入，LED 作為輸出，並自動遍歷所有 0/1 組合：

        div(class="overflow-auto flex-1 rounded-lg border border-slate-700 bg-slate-900 shadow-inner")
          table(class="w-full text-center border-collapse")
            thead#tt-head(class="bg-slate-700 text-slate-200 sticky top-0 shadow")
              // JS 產生標題
            tbody#tt-body(class="text-slate-300 font-mono")
              // JS 產生資料列

        div(class="mt-4 flex justify-end")
          button(onclick="closeTTModal()", class="bg-slate-600 hover:bg-slate-500 px-6 py-2 rounded text-white font-bold transition shadow") 關閉

    script(src="/javascripts/gate.js")
